{
  "name": "crowcoder-cli",
  "version": "1.1.0",
  "description": "Universal AI coding CLI — works with OpenRouter, GLM, Ollama, or any OpenAI-compatible API. Bundled with the everything-claude-code skill, agent, command, and rule library.",
  "type": "module",
  "bin": {
    "crowcoder": "./bin/crowcoder.js",
    "anycode": "./bin/crowcoder.js"
  },
  "files": [
    "bin/",
    "dist/",
    "resources/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "tsx src/index.ts",
    "dev": "tsx --watch src/index.ts"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "glob": "^11.0.0",
    "openai": "^4.73.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.6",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.6"
  }
}
